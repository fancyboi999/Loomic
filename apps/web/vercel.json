{
  "buildCommand": "cd ../.. && pnpm --filter @loomic/shared build && pnpm --filter @loomic/web build",
  "outputDirectory": "out",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/((?!_next|favicon|logo|og-image|apple-touch-icon).*)", "destination": "/index.html" }
  ]
}
