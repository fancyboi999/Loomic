# Loomic local development

# Server origin config
LOOMIC_SERVER_PORT=3001
LOOMIC_WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_SERVER_BASE_URL=http://localhost:3001

# Existing agent runtime config
LOOMIC_AGENT_BACKEND_MODE=state
LOOMIC_AGENT_MODEL=gpt-5.4-mini
LOOMIC_AGENT_FILES_ROOT=
OPENAI_API_BASE=your_base_url
OPENAI_API_KEY=your_api_key
REPLICATE_API_TOKEN=your_api_key
GOOGLE_FONTS_API_KEY=your-api-key

# Supabase server config
# Secret: keep SUPABASE_SERVICE_ROLE_KEY on the server only.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_DB_URL='postgresql://postgres:<SECRET>@DBHOST:PORT/postgres'
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT public key (JWK JSON) from Supabase Settings > API > JWT Settings, for local token verification
SUPABASE_JWT_SECRET={"x":"...","y":"...","alg":"ES256","crv":"P-256","kty":"EC","key_ops":["verify"]}
SUPABASE_PROJECT_ID=your-project-ref

# Supabase browser-safe config
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini (optional, fallback when OpenAI unavailable)
GOOGLE_API_KEY=your-google-api-key

# Volces TTS (optional)
VOLCES_API_KEY=
VOLCES_BASE_URL=

# ── Skills & Sandbox ──
# Skills root for local development (Docker uses /opt/loomic/skills by default)
# dev script cwd is apps/server/, so use relative path from there
LOOMIC_SKILLS_ROOT=../../skills

# Worker config (optional, defaults shown)
# WORKER_CODE_CONCURRENCY=3
# WORKER_IMAGE_CONCURRENCY=3
# WORKER_VIDEO_CONCURRENCY=2
# WORKER_POLL_INTERVAL_MS=2000

# Proxy for global-agent (Supabase outbound requests), just for local dev
GLOBAL_AGENT_HTTP_PROXY=http://your-proxy